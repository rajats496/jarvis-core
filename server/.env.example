# Server
NODE_ENV=production
PORT=3000

# MongoDB Atlas (replace with your Atlas connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/jarvis?retryWrites=true&w=majority

# JWT — generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed frontend origins (no trailing slash)
# e.g. https://jarvis.vercel.app,https://www.jarvis.app
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# AI (Groq free tier at console.groq.com)
GROQ_API_KEY=your-groq-api-key
AI_TIMEOUT_MS=10000
GROQ_MODEL=llama-3.1-8b-instant

# Vector semantic memory (optional; fallback to keyword if unset)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_EMBED_MODEL=text-embedding-3-small

# VM Microservice URL (optional)
# VM_SERVICE_URL=http://your-ec2-ip:4000
